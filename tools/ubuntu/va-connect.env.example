APP_NAME="VA-Connect"
APP_MATCH="/home/vsuser/vsgwgui/vsgwgui"
APP_START_CMD="bash -c \"cd /home/vsuser/vsgwgui; /home/vsuser/vsgwgui/vsgwgui\""
APP_WORKDIR="/home/vsuser/vsgwgui"
WATCHDOG_LOG="/var/log/va-connect-watchdog.log"
STATE_DIR="/var/lib/va-connect-watchdog"
COOLDOWN_FILE="/var/lib/va-connect-watchdog/last_start_epoch"
START_COOLDOWN_SECONDS="30"
STARTUP_GRACE_SECONDS="15"
